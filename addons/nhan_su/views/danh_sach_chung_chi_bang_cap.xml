<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_danh_sach_cc_form" model="ir.ui.view">
        <field name="name">danh_sach_chung_chi.form</field>
        <field name="model">danh_sach_chung_chi_bang_cap</field>
        <field name="arch" type="xml">
            <form string="Danh sách chứng chỉ">
                <sheet>
                    <group>
                        <field name="nhan_vien_id"/>
                        <field name="chung_chi_id"/>
                        <field name="loai_chung_chi"/>
                        <field name="ngay_cap"/>
                        <field name="noi_cap"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_danh_sach_cc_tree" model="ir.ui.view">
        <field name="name">danh_sach_chung_chi.tree</field>
        <field name="model">danh_sach_chung_chi_bang_cap</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhan_vien_id"/>
                <field name="chung_chi_id"/>
                <field name="loai_chung_chi"/>
                <field name="ngay_cap"/>
                <field name="noi_cap"/>
            </tree>
        </field>
    </record>

    <record id="action_danh_sach_cc" model="ir.actions.act_window">
        <field name="name">Danh sách chứng chỉ</field>
        <field name="res_model">danh_sach_chung_chi_bang_cap</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
