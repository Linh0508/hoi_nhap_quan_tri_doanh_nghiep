<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien.form</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="anh" widget="image" class="oe_avatar" options='{"preview_image": "anh"}'/>
                        
                        <div class="oe_title">
                            <label for="ho_va_ten" class="oe_edit_only"/>
                            <h1>
                                <field name="ho_va_ten" readonly="1"/>
                            </h1>
                            <label for="ma_dinh_danh" class="oe_edit_only"/>
                            <h3>
                                <field name="ma_dinh_danh" placeholder="VD: NV001"/>
                            </h3>
                        </div>

                        <group string="Thông tin cá nhân">
                            <group>
                                <field name="ho_ten_dem"/>
                                <field name="ten"/>
                                <field name="gioi_tinh"/>
                                <field name="ngay_sinh"/>
                                <field name="tuoi"/>
                            </group>
                            <group>
                                <field name="email" widget="email"/>
                                <field name="so_dien_thoai" widget="phone"/>
                                <field name="que_quan"/>
                            </group>
                        </group>

                        <group string="Thông tin công tác hiện tại">
                            <group>
                                <field name="phong_ban_id" options="{'no_create': True}"/>
                                <field name="chuc_vu_id" options="{'no_create': True}"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Lịch sử công tác" name="work_history">
                                <field name="lich_su_cong_tac_ids">
                                    <tree editable="bottom">
                                        <field name="phong_ban_id"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="trang_thai" widget="badge" decoration-success="trang_thai == 'Đang giữ'"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Bằng cấp &amp; Chứng chỉ" name="certificates">
                                <field name="danh_sach_chung_chi_bang_cap_ids">
                                    <tree editable="bottom">
                                        <field name="chung_chi_id"/>
                                        <field name="loai_chung_chi"/>
                                        <field name="ngay_cap"/>
                                        <field name="noi_cap"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien.tree</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree string="Danh sách nhân viên">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_va_ten"/>
                    <field name="gioi_tinh"/>
                    <field name="ngay_sinh" optional="hide"/>
                    <field name="tuoi"/>
                    <field name="phong_ban_id"/>
                    <field name="chuc_vu_id"/>
                    <field name="so_dien_thoai" widget="phone"/>
                    <field name="email" widget="email"/>
                </tree>
            </field>
        </record>

        <record id="view_nhan_vien_search" model="ir.ui.view">
            <field name="name">nhan_vien.search</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ho_va_ten" string="Tên hoặc Mã" filter_domain="['|', ('ho_va_ten', 'ilike', self), ('ma_dinh_danh', 'ilike', self)]"/>
                    <field name="phong_ban_id"/>
                    <field name="chuc_vu_id"/>
                    <separator/>
                    <filter string="Nam" name="male" domain="[('gioi_tinh', '=', 'Nam')]"/>
                    <filter string="Nữ" name="female" domain="[('gioi_tinh', '=', 'Nữ')]"/>
                    <group expand="0" string="Gom nhóm theo">
                        <filter string="Phòng ban" name="group_by_phong_ban" context="{'group_by': 'phong_ban_id'}"/>
                        <filter string="Chức vụ" name="group_by_chuc_vu" context="{'group_by': 'chuc_vu_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_nhan_vien_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Chưa có nhân viên nào. Hãy tạo mới!
                </p>
            </field>
        </record>
    </data>
</odoo>