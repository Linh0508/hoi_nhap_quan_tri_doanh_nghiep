<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kế thừa form nhân viên gốc -->
    <record id="view_employee_form_inherit_qlns" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.qlns</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Thêm tab mới -->
            <xpath expr="//notebook" position="inside">

                <page string="Thông tin bổ sung">
                    <group>
                        <field name="ma_dinh_danh"/>
                        <field name="cccd"/>
                        <field name="que_quan"/>
                        <field name="tuoi" readonly="1"/>
                    </group>
                </page>

                <page string="Lịch sử công tác">
                    <field name="lich_su_cong_tac_ids">
                        <tree editable="bottom">
                            <field name="phong_ban_id"/>
                            <field name="chuc_vu_id"/>
                            <field name="ngay_bat_dau"/>
                            <field name="ngay_ket_thuc"/>
                            <field name="trang_thai" widget="badge"/>
                        </tree>
                    </field>
                </page>

                <page string="Chứng chỉ &amp; Bằng cấp">
                    <field name="danh_sach_chung_chi_bang_cap_ids">
                        <tree editable="bottom">
                            <field name="chung_chi_id"/>
                            <field name="loai_chung_chi"/>
                            <field name="ngay_cap"/>
                            <field name="noi_cap"/>
                        </tree>
                    </field>
                </page>

            </xpath>

        </field>
    </record>

</odoo>
