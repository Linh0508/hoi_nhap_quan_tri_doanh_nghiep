<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bang_luong_tree_upgrade" model="ir.ui.view">
        <field name="name">tinh.luong.bang.luong.tree.upgrade</field>
        <field name="model">tinh.luong.bang.luong</field>
        <field name="arch" type="xml">
            <tree string="Danh sách bảng lương"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'paid'">

                <field name="ma_dinh_danh"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="so_cong_thuc_te"/>
                <field name="luong_net" sum="Tổng quỹ lương" widget="monetary"/>

                <field name="state"
                       widget="badge"
                       decoration-info="state == 'confirmed'"
                       decoration-success="state == 'paid'"/>

            </tree>
        </field>
    </record>

    <record id="view_bang_luong_form_upgrade" model="ir.ui.view">
        <field name="name">tinh.luong.bang.luong.form.upgrade</field>
        <field name="model">tinh.luong.bang.luong</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_compute_salary"
                            string="Tính lương"
                            type="object"
                            states="draft"
                            class="btn-secondary"/>

                    <button name="action_confirm"
                            string="Xác nhận"
                            type="object"
                            states="draft"
                            class="oe_highlight"/>

                    <button name="action_pay"
                            string="Đã thanh toán"
                            type="object"
                            states="confirmed"
                            class="oe_highlight"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,paid"/>
                </header>

                <sheet>

                    <group>
                        <group string="Kỳ lương">
                            <field name="ma_dinh_danh"/>
                            <field name="thang"/>
                            <field name="nam"/>
                        </group>

                        <group string="Thông tin công">
                            <field name="ngay_cong_chuan"/>
                            <field name="so_cong_thuc_te"/>
                            <field name="so_lan_muon"/>
                            <field name="so_gio_tang_ca" widget="float_time"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Thu nhập &amp; Khấu trừ">
                            <group>
                                <group string="Thu nhập">
                                    <field name="tien_tang_ca" widget="monetary"/>
                                    <field name="tien_an_trua" widget="monetary"/>
                                    <field name="tien_xang_xe" widget="monetary"/>
                                    <field name="tien_thuong_kpi" widget="monetary"/>
                                </group>

                                <group string="Khấu trừ">
                                    <field name="tien_phat_muon" widget="monetary"/>
                                    <field name="bhxh_nv" widget="monetary"/>
                                    <field name="thue_tncn" widget="monetary"/>
                                </group>
                            </group>

                            <group class="oe_subtotal_footer">
                                <field name="tong_thu_nhap" widget="monetary"/>
                                <field name="tong_khau_tru" widget="monetary"/>
                                <field name="luong_net"
                                       widget="monetary"
                                       style="font-size:1.4em;"/>
                            </group>
                        </page>

                        <page string="Chi tiết lương">
                            <field name="line_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="line_type"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="action_bang_luong" model="ir.actions.act_window">
        <field name="name">Bảng Lương Tháng</field>
        <field name="res_model">tinh.luong.bang.luong</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
